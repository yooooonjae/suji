# 「수지(收支)」 API 키 — 발급처별 키 이름만 (값은 비움).
# 실제 사용 위치: 저장소 루트의 config.json (아래와 동일한 키 이름의 JSON).
#   예) { "service_key": "...", "ecos_key": "...", ... }
# config.json 은 .gitignore 로 커밋되지 않는다. 각 포털에서 무료 발급.

# 공공데이터포털(data.go.kr) — RTMS 실거래·HUG 분양가·상가업소·건축HUB 공용 인증키
service_key=

# 한국은행 경제통계시스템(ECOS) — 기준금리·대출금리
ecos_key=

# 통계청 국가통계포털(KOSIS) — 미분양·공급·건설공사비지수
kosis_key=

# 한국부동산원 부동산통계정보(R-ONE) — 가격지수·상업용 임대동향
rone_key=

# 주택도시보증공사(HUG) — 민간아파트 분양가격 동향
hug_key=

# 디지털트윈국토(브이월드, VWorld) — 지오코딩·개별공시지가 실조회
vworld_key=
